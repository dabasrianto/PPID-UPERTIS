# ==============================================
# UPERTIS Backend — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ==============================================

# Server
PORT=3001
CORS_ORIGINS=https://app.upertis.ac.id
SITE_DOMAIN=https://app.upertis.ac.id

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=disable

# Authentication (minimum 32 characters)
JWT_SECRET=

# Super Admin (optional — only for first-time setup)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME=Super Admin

# Google Client ID for OAuth 2.0
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

